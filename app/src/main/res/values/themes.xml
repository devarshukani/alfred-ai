<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Alfredai" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="Theme.Alfredai.Transparent" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.3</item>
        <item name="android:windowAnimationStyle">@style/FadeAnimation</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
    </style>
</resources>