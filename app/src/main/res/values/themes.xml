<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Alfredai" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="Theme.Alfredai.Transparent" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.5</item>
        <item name="android:windowAnimationStyle">@style/FadeAnimation</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
    </style>

    <!-- Solid dark theme for the main dashboard activity -->
    <style name="Theme.Alfredai.Solid" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowAnimationStyle">@style/FadeAnimation</item>
    </style>

    <!-- Full-screen theme for cover wave activity on Flex Window -->
    <style name="Theme.Alfredai.CoverWave" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowAnimationStyle">@style/FadeAnimation</item>
    </style>
</resources>